modules = ["python-3.11"]
[agent]
expertMode = true
integrations = ["python_openai:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "glibcLocales", "gobject-introspection", "gtk3", "gumbo", "harfbuzz", "jbig2dec", "libjpeg_turbo", "libxcrypt", "mupdf", "openjpeg", "pkg-config", "qhull", "swig", "ta-lib", "tcl", "tk", "xcbuild"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Trading Signal Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mirofish_bot.py"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Main Trading Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AEGIS GEX v1.0"

[[workflows.workflow]]
name = "Main Trading Bot"
mode = "parallel"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 start_ultimate_bot.py"

[[workflows.workflow]]
name = ""
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ""

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "FLASK_PORT=8000 python mirofish_bot.py"
mode = "sequential"
author = 47973864

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "mirofish_bot.py"

[[workflows.workflow]]
name = "AEGIS GEX v1.0"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 start_aegis_gex_bot.py"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5173

[[ports]]
localPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 9080
externalPort = 9000

[deployment]
run = ["sh", "-c", "python dynamic_comprehensive_error_fixer.py && python bot_health_check.py && python main.py"]
deploymentTarget = "gce"
ignorePorts = true


# ──────────────────────────────────────────────────────────────────────────────
# MiroFish Swarm + G0DM0D3 AI Trading Bot — Environment Variables
# Copy this file to .env for local development, or paste values into the
# Railway dashboard → Variables tab for production deployment.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Models (PRIMARY — REQUIRED) ───────────────────────────────────────────
# G0DM0D3 Engine / ULTRAPLINIAN multi-model racing via OpenRouter
# Get your key at: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ── AI Models (OPTIONAL FALLBACKS) ───────────────────────────────────────────
# Bot works without these — OpenRouter/G0DM0D3 handles all AI calls
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Binance USDM Futures (REQUIRED) ──────────────────────────────────────────
# Create a read-only API key (no trade permissions needed — bot only reads data)
# at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=...
BINANCE_API_SECRET=...

# ── Telegram (REQUIRED) ───────────────────────────────────────────────────────
# Create bot at: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=...
# Channel to send signals to (e.g. -1001234567890 or @channelname)
TELEGRAM_CHANNEL_ID=-1003031984142
# Admin chat ID for error alerts (your personal chat ID)
TELEGRAM_CHAT_ID=1548826223

# ── Railway / Production Settings (OPTIONAL) ──────────────────────────────────
# Persistent SQLite data directory (mount Railway volume here)
DATA_DIR=/data
# Health check HTTP port (Railway pings this)
PORT=8080

# ── Bot Tuning (OPTIONAL — defaults shown) ───────────────────────────────────
# Max concurrent symbol scans per cycle (Binance rate-limit safe zone)
SCAN_PARALLEL_LIMIT=15
# Hourly signal limits
SIGNALS_PER_HOUR_MIN=5
SIGNALS_PER_HOUR_MAX=10
# Minimum AI confidence % to send a signal
AI_THRESHOLD_PERCENT=80

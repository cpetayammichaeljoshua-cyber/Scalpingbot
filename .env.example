# ═══════════════════════════════════════════════════════════════════════════════
# Unity Engine v8.2 — Environment variables template
# Production secrets management (Railway, Docker, Kubernetes)
#
# ── For local Docker deployment ────────────────────────────────────────────────
#   cp .env.example .env
#   # fill in your values, then:
#   docker-compose up -d
#
# ── For Railway.app deployment ─────────────────────────────────────────────────
#   Add each variable via: Railway Dashboard → Project → Variables
#   OR use Railway CLI: railway variables set KEY=value
#   Railway injects $PORT automatically (no need to set HEALTH_PORT on Railway).
#
# NEVER commit .env to version control. Add .env to your .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHANNEL_ID=-1003031984142          # signal broadcast channel
TELEGRAM_CHAT_ID=1548826223                 # admin/owner personal chat

# ── Binance API ────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ── AI / LLM keys ─────────────────────────────────────────────────────────────
# OpenRouter is the PRIMARY LLM provider (covers 10+ free models via G0DM0D3)
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: v8.0 LLMKeyRotator backup keys — engine cycles PRIMARY → BACKUP_1 → BACKUP_2
# on HTTP 429 (rate-limit) or 5xx errors for zero-downtime key rotation.
OPENROUTER_API_KEY_BACKUP_1=
OPENROUTER_API_KEY_BACKUP_2=

# Optional: Claude (Anthropic) — used as secondary AI fallback cascade
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: OpenAI — used as tertiary AI fallback
OPENAI_API_KEY=your_openai_key_here

# ── Optional: runtime tuning ───────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR

# Health server port — Railway sets $PORT automatically, this is the local override
# On Railway: do NOT set this; Railway injects $PORT and Unity Engine reads it.
# UNITY_HEALTH_PORT=8080                   # uncomment only for non-Railway deployments

UTBOT_ENABLED=1                            # 1=on, 0=off (UT Bot + STC strategy layer)

# ── Redis state caching (optional but recommended on Railway) ─────────────
# When a Redis service exists in the same Railway project, link it here so
# the Unity Engine can cache engine state and survive container restarts.
#
# Railway variable reference syntax (add this in the Scalpingbot service
# Variables tab — do NOT paste a literal URL, use the reference so Railway
# resolves it automatically even if the Redis internal host changes):
#
#   REDIS_URL = ${{Redis.REDIS_URL}}
#
# For local Docker testing you can set a literal URL instead:
#   REDIS_URL=redis://default:yourpassword@localhost:6379
#
# Leave unset (or empty) to disable Redis and fall back to local file persistence.
REDIS_URL=

# ── Railway-specific notes ────────────────────────────────────────────────────
# 1. railway.json sets build.builder=DOCKERFILE → uses the Dockerfile above
# 2. railway.json deploy.healthcheckPath=/healthz (liveness probe, 120s timeout)
# 3. Restart policy: ON_FAILURE with 100 max retries (matches DEFAULT_MAX_RESTARTS)
# 4. Unity Engine launcher uses exponential backoff: 30s → 60s → 120s → 240s → 480s
#
# ── Persistent storage on Railway (IMPORTANT) ─────────────────────────────────
# Railway does NOT support the Docker VOLUME instruction in Dockerfiles.
# To persist SQLite databases, NN weights, and metrics JSON across deploys:
#   Railway Dashboard → your service → Volumes → Add Volume
#   Mount path 1: /app/SignalMaestro   (trade_history.db, NN weights, metrics)
#   Mount path 2: /app/logs            (engine rotating file logs)
# Without Railway Volumes, state resets on each deploy — engine still runs fine.
